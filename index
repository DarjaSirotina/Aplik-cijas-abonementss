<!DOCTYPE html>
<html lang="lv">
<head>
    <meta charset="UTF-8">
    <title>Lietotnes Abonēšana</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1 id="main-title">Premium Lietotnes Abonements</h1>
        <p>Izvēlieties sev piemērotāko plānu un baudiet visas funkcijas!</p>
        
        <div class="input-section">
            <label for="period-select">Izvēlieties periodu:</label>
            <select id="period-select">
                <option value="1">1 mēnesis - 10 EUR</option>
                <option value="12">12 mēneši (Gads) - 100 EUR</option>
            </select>
            
            <button id="calc-btn">Aprēķināt cenu</button>
        </div>

        <div id="result-area" class="result-box">
            </div>
    </div>
    <script src="script.js"></script>
</body>
</html>
